PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# SQL Server Database
DB_HOST=localhost
DB_PORT=1433
DB_NAME=GymFit
DB_USER=sa
DB_PASSWORD=YourStrongPassword

# JWT Secrets (change in production!)
JWT_SECRET=gymfit-jwt-secret-dev-change-in-production
JWT_REFRESH_SECRET=gymfit-jwt-refresh-secret-dev-change-in-production

# Cloudinary (for image uploads — optional, leave empty to disable)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google OAuth (get from Firebase Console > Project Settings > General > Web client ID)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=